                  </motion.a>
                </motion.div>
                
              </div>
            </motion.div>
          </div>
        </section>

        {/* --- THE INVENTORY --- */}
        <section className="max-w-7xl mx-auto px-8 py-80">
          <div className="mb-24 flex items-center justify-between">
