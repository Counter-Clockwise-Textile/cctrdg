'use client';

import React, { useEffect, useState, useMemo, useRef } from 'react';
import { motion, useScroll, useSpring, useTransform, useMotionValue } from 'framer-motion';
import { GeistSans } from "geist/font/sans";

// --- Design System ---
const DESIGN_SYSTEM = {
  colors: {
    accent: '#3b82f6',
    bg: '#050505',
    border: 'rgba(255, 255, 255, 0.08)',
  },
  animations: {
    stiffness: 80,
    damping: 25,
  }
};

// --- Atomic Logic ---
function useHasMounted() {
  const [hasMounted, setHasMounted] = useState(false);
  useEffect(() => setHasMounted(true), []);
  return hasMounted;
}

// --- High-Complexity Components ---

/**
 * RE-ENGINEERED: Reactive Metal Surface
 * Acts as a light-sensitive plate that reacts to mouse coordinates.
 */
const ReactiveMetalSurface = ({ mouseX, mouseY }: { mouseX: any, mouseY: any }) => {
  const x = useTransform(mouseX, [0, 2000], [5, -5]);
  const y = useTransform(mouseY, [0, 1200], [5, -5]);

  return (
    <motion.div 
      style={{ x, y }}
      className="pointer-events-none fixed inset-[-5%] z-[10] opacity-[0.08] select-none scale-110"
    >
      <div 
        className="absolute inset-0" 
        style={{ 
          backgroundImage: `url('https://www.transparenttextures.com/patterns/brushed-alum.png')`,
          backgroundSize: '800px' 
        }} 
      />
      {/* Dynamic Cursor Light (The "Flashlight" effect) */}
      <motion.div 
        style={{ 
          left: mouseX, 
          top: mouseY,
          background: `radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 60%)`
        }}
        className="absolute w-[600px] h-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full blur-3xl"
      />
    </motion.div>
  );
};

const VolumetricClock = ({ mouseX, mouseY }: { mouseX: any, mouseY: any }) => {
  const x = useTransform(mouseX, [0, 2000], [-15, 15]);
  const y = useTransform(mouseY, [0, 1200], [-15, 15]);
  const ticks = useMemo(() => Array.from({ length: 60 }), []);

  return (
    <motion.div style={{ x, y }} className="fixed inset-0 z-0 flex items-center justify-center pointer-events-none opacity-[0.15]">
      <div className="relative w-[95vw] h-[95vw] max-w-[900px] max-h-[900px] rounded-full border border-blue-500/10 shadow-[0_0_100px_rgba(59,130,246,0.05)]">
        {ticks.map((_, i) => (
          <div 
            key={i} 
            className="absolute top-0 left-1/2 -translate-x-1/2 origin-bottom transition-all duration-1000"
            style={{
              height: i % 5 === 0 ? '30px' : '12px',
              width: i % 5 === 0 ? '2px' : '1px',
              backgroundColor: i % 5 === 0 ? 'rgba(59, 130, 246, 0.4)' : 'rgba(255, 255, 255, 0.1)',
              transform: `rotate(${i * 6}deg)`,
              transformOrigin: `0 450px` 
            }}
          />
        ))}
      </div>
    </motion.div>
  );
};

const ReverseTimer = () => {
  const [time, setTime] = useState(999999);
  const mounted = useHasMounted();
  useEffect(() => {
    if (!mounted) return;
    const interval = setInterval(() => setTime(p => (p <= 0 ? 999999 : p - 1)), 100);
    return () => clearInterval(interval);
  }, [mounted]);
  return (
    <div className="font-mono text-3xl tracking-[0.4em] text-blue-500 drop-shadow-[0_0_15px_rgba(59,130,246,0.5)]">
      {mounted ? time.toString().padStart(6, '0') : "000000"}
    </div>
  );
};

const ProductCard = ({ title, year, category }: { title: string; year: string; category: string }) => (
  <motion.div 
    whileHover={{ y: -10, borderColor: 'rgba(59, 130, 246, 0.5)', backgroundColor: '#0c0c0c' }}
    className="relative group p-14 border border-white/5 bg-[#080808]/80 backdrop-blur-sm transition-all overflow-hidden cursor-pointer shadow-2xl"
  >
    <div className="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity bg-gradient-to-br from-blue-600/10 to-transparent" />
    <div className="relative z-10">
      <div className="flex justify-between items-start mb-28">
        <span className="font-mono text-[10px] text-white/20 tracking-[0.3em]">{year} // DATA_NODE</span>
        <motion.div 
          animate={{ scale: [1, 1.5, 1] }} 
          transition={{ repeat: Infinity, duration: 2 }}
          className="w-2 h-2 rounded-full bg-blue-500" 
        />
      </div>
      <h3 className="text-4xl font-black uppercase tracking-tighter mb-3 group-hover:text-blue-400 transition-colors">{title}</h3>
      <p className="font-mono text-[9px] uppercase tracking-[0.5em] text-white/10 italic">{category}</p>
    </div>
  </motion.div>
);

// --- Master Page ---
