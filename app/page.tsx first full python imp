                    <div className="h-[1px] w-12 bg-white" />
                  </div>
                  <ReverseTimer />
                </div>

                {/* LOGO CORE */}
                <div className="relative w-full flex justify-center py-4">
                  <div className="absolute -top-4 -left-4 w-12 h-12 border-t-2 border-l-2 border-blue-500/20 group-hover:border-blue-500/50 transition-colors" />
                  <div className="absolute -bottom-4 -right-4 w-12 h-12 border-b-2 border-r-2 border-blue-500/20 group-hover:border-blue-500/50 transition-colors" />
                  
                  <img 
                    src="/clockwise_precision.gif" 
                    alt="Kinetic Asset" 
                    className="w-full h-auto max-w-[780px] mix-blend-screen drop-shadow-[0_0_30px_rgba(59,130,246,0.1)]"
                  />
                </div>

                {/* THE "DOCKABLE" ACCESS LINK */}
                <motion.div 
                  className="relative z-[100] mt-[-10%] md:mt-[-16%]"
